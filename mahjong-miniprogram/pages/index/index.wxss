.page {
  padding: 48rpx 32rpx 64rpx;
}

.hero {
  margin-bottom: 48rpx;
}

.title {
  font-size: 48rpx;
  font-weight: 700;
  display: block;
  margin-bottom: 16rpx;
}

.subtitle {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.8);
}

.mode-card {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
  margin-bottom: 32rpx;
}

.mode-title {
  font-size: 32rpx;
  font-weight: 600;
}

.mode-desc {
  font-size: 24rpx;
  margin-top: 8rpx;
}

.info-card {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.info-title {
  font-size: 28rpx;
  font-weight: 600;
}

.info-list text {
  display: block;
  font-size: 24rpx;
  margin-bottom: 8rpx;
}
