page {
  font-family: "PingFang SC", "Microsoft YaHei", sans-serif;
  background: #0b3b22;
  color: #f7f7f7;
}

.button-primary {
  background: linear-gradient(135deg, #f8c05e, #f08e2a);
  color: #2a1b00;
  border-radius: 999px;
  padding: 18rpx 40rpx;
  font-weight: 600;
}

.card {
  background: rgba(255, 255, 255, 0.08);
  border-radius: 24rpx;
  padding: 24rpx;
  box-shadow: 0 18rpx 36rpx rgba(0, 0, 0, 0.25);
}

.text-muted {
  color: rgba(255, 255, 255, 0.7);
}
